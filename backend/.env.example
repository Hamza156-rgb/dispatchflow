# Backend environment — copy to `.env` and fill in your values
# PostgreSQL connection string
DATABASE_URL="postgresql://dispatchflow:dispatchflow_secret@localhost:5432/dispatchflow"

# Secret for signing JWTs (use a long random string, 32+ chars)
JWT_SECRET="change-me-to-a-long-random-secret"

# API server port
PORT=5000

# CORS origin (frontend URL). Any localhost port is also allowed in dev.
FRONTEND_URL="http://localhost:5173"

# SMTP (optional — only needed for the "email invoice" feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
